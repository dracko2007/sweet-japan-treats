rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin identificado pelo e-mail autenticado no Firebase Auth.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'dracko2007@gmail.com';
    }

    // ---------- Clientes ----------
    match /users/{userId} {
      // Admin lê tudo; usuário lê/edita apenas o próprio documento.
      allow read: if isAdmin() || (request.auth != null && userId == request.auth.uid);
      allow create: if request.auth != null && userId == request.auth.uid;
      allow update: if isAdmin() || (request.auth != null && userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ---------- Pedidos ----------
    match /orders/{orderId} {
      // Admin lê tudo; usuário lê apenas seus próprios pedidos (por uid ou e-mail).
      allow read: if isAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid)
        || (request.auth != null && resource.data.customerEmail == request.auth.token.email);
      // Qualquer pessoa (convidado) cria um pedido com status 'pending'.
      allow create: if request.resource.data.status == 'pending';
      // Admin atualiza status/rastreio; usuário autenticado não pode alterar pedidos de outros.
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---------- Produtos ----------
    match /products/{productId} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // ---------- Conteúdo do site (home) ----------
    match /siteContent/{docId} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // ---------- Cupons ----------
    match /coupons/{couponId} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /coupon_usage/{usageId} {
      // Usuário lê apenas seus próprios registros de uso.
      allow read: if isAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // ---------- Eventos de navegação ----------
    match /eventos/{eventoId} {
      allow create: if request.auth != null
                    && request.resource.data.usuarioId == request.auth.uid;
      allow read: if (request.auth != null
                    && resource.data.usuarioId == request.auth.uid)
                    || isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ---------- Afiliados / Influencers ----------
    match /affiliates/{code} {
      // Leitura pública para validar código no checkout.
      allow read: if true;
      // Criação e remoção: somente admin.
      allow create, delete: if isAdmin();
      // Update: admin ou o próprio dono do código (painel do influencer).
      allow update: if isAdmin()
        || (request.auth != null && resource.data.ownerEmail == request.auth.token.email);
    }

    // Comissões pendentes
    match /affiliate_pending/{id} {
      allow create: if request.resource.data.status == 'pending';
      allow read, update, delete: if isAdmin()
        || (request.auth != null && resource.data.buyerEmail == request.auth.token.email);
    }

    // Solicitações para virar afiliado
    match /affiliate_requests/{id} {
      allow create: if true;
      allow read: if isAdmin()
        || (request.auth != null && resource.data.email == request.auth.token.email);
      allow update, delete: if isAdmin();
    }

    // ---------- Administradores ----------
    // A leitura de um doc individual é necessária ANTES da autenticação Firebase
    // (login por username + senha). 'get' permite isso; 'list' (listar todos) é
    // restrito ao admin para evitar enumeração em massa.
    match /admins/{adminId} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // ---------- Settings (manutenção, config) ----------
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- Pedidos personalizados ----------
    match /custom_requests/{reqId} {
      allow create: if request.resource.data.status == 'new';
      allow read, update, delete: if isAdmin();
    }

    // ---------- Cotações B2B ----------
    match /b2b_requests/{reqId} {
      allow create: if request.resource.data.status == 'new';
      allow read, update, delete: if isAdmin();
    }

    // ---------- Vídeos de review ----------
    match /video_reviews/{id} {
      allow create: if request.resource.data.status == 'pending';
      // Leitura: dono do vídeo ou admin.
      allow read: if isAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid)
        || (request.auth != null && resource.data.userEmail == request.auth.token.email);
      allow update, delete: if isAdmin();
    }

    // ---------- Coleção de teste ----------
    match /test/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}

# ========================================
# EMAIL CONFIGURATION
# ========================================

# Option 1: Resend API (requires backend or serverless)
# Get your API key at: https://resend.com/api-keys
VITE_RESEND_API_KEY=re_123456789
VITE_FROM_EMAIL=pedidos@sabordocampo.com

# Option 2: EmailJS (works in frontend, easier setup!)
# Get credentials at: https://www.emailjs.com/
# See EMAILJS_SETUP.md for detailed instructions
VITE_EMAILJS_SERVICE_ID=service_abc123
VITE_EMAILJS_TEMPLATE_ID=template_xyz789
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Store SMTP used by /api/send-email (server-side only)
ZOHO_MAIL_PASSWORD=your_zoho_app_password

# Firebase Admin for generating official email verification links in /api/send-email.
# Use either FIREBASE_SERVICE_ACCOUNT_JSON or the three split variables below.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...@....iam.gserviceaccount.com"}
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ========================================
# WHATSAPP CONFIGURATION
# ========================================

# Option 1: Twilio API (automatic sending)
# Get credentials at: https://console.twilio.com
VITE_TWILIO_ACCOUNT_SID=AC1234567890abcdef
VITE_TWILIO_AUTH_TOKEN=your_auth_token
VITE_TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Option 2: Simple WhatsApp (always works, opens WhatsApp Web/App)
# No configuration needed! Falls back automatically.

# ========================================
# STORE INFORMATION
# ========================================

# Store Contact
VITE_STORE_PHONE=070-1367-1679
VITE_STORE_EMAIL=paula@sabordocampo.com

# Social links (usados na página de Vlog)
VITE_YOUTUBE_URL=https://www.youtube.com/@seucanal
VITE_INSTAGRAM_URL=https://www.instagram.com/seuperfil

# ========================================
# ADMIN CREDENTIALS (OBRIGATÓRIO em produção)
# ========================================
# Defina no Vercel: Settings → Environment Variables.
# Sem estas variáveis o login de super-admin fica inativo (senha vazia não autoriza).
VITE_ADMIN_EMAIL=dracko2007@gmail.com
VITE_ADMIN_PASSWORD=troque-esta-senha-forte

# ========================================
# AI / PRODUCT ENRICHMENT (serverless)
# ========================================
# Groq API — KimiClaw + Auto-preencher produto.
# Cadastre grátis em https://console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxx

# Rakuten Ichiba API — busca preço e fotos reais de produtos japoneses.
# Cadastre grátis em https://webservice.rakuten.co.jp → Criar aplicação
# Sem esta chave o Auto-preencher usa só a IA (preço estimado, sem fotos reais).
RAKUTEN_APP_ID=1234567890123456789

rules_version = '2';

// Regras do Firebase Storage.
// Os clientes da loja NÃO têm sessão Firebase Auth (só o admin autentica),
// então a escrita nas pastas de mídia de avaliação é liberada, mas com limites
// rígidos de tamanho e tipo para evitar abuso. Leitura é pública (mostrar mídia).
service firebase.storage {
  match /b/{bucket}/o {

    // Vídeos de avaliação: até 60MB, só content-type de vídeo.
    match /review-videos/{productId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 60 * 1024 * 1024
                   && request.resource.contentType.matches('video/.*');
    }

    // Fotos de avaliação (caso passem a subir aqui): até 8MB, só imagem.
    match /review-photos/{productId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Qualquer outro caminho: bloqueado.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
